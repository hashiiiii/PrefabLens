{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": [
      "chrome"
    ]
  },
  "include": [
    "*.ts",
    "src/**/*",
    "e2e/**/*"
  ]
}