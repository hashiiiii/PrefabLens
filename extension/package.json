{
  "name": "prefablens-extension",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "node build.mjs",
    "demo": "node build.mjs --demo",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci --reporter=default .",
    "fmt": "biome check --write .",
    "pretest": "zig build wasm",
    "test": "vitest run",
    "size": "node scripts/check-wasm-size.mjs",
    "e2e": "node build.mjs --e2e && playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
