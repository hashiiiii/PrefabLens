{
    "editor.formatOnSave": true,
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[zig]": {
        "editor.defaultFormatter": "ziglang.vscode-zig"
    },
    "[csharp]": {
        "editor.defaultFormatter": "csharpier.csharpier-vscode"
    },
    "zig.zls.enabled": "on",
    "zig.path": "${userHome}/.local/share/mise/shims/zig",
    "zig.zls.path": "${userHome}/.local/share/mise/shims/zls",
    "zig.testArgs": [
        "build",
        "test",
        "-Dtest-filter=${filter}"
    ],
}